<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- iisnode handler — routes all requests through server.js -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Serve static files from .next/static directly (faster, no Node overhead) -->
        <rule name="Next.js Static" stopProcessing="true">
          <match url="^_next/static/.*" />
          <action type="Rewrite" url=".next/static/{R:0}" />
        </rule>

        <!-- Serve public folder files directly -->
        <rule name="Public Assets" stopProcessing="true">
          <match url="^(uploads|images|fonts|icons)/.*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" />
          </conditions>
          <action type="None" />
        </rule>

        <!-- Route everything else through Next.js server -->
        <rule name="Next.js App" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- iisnode settings -->
    <iisnode
      nodeProcessCommandLine="node.exe"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
      maxNamedPipeConnectionRetry="100"
      namedPipeConnectionRetryDelay="250"
    />

    <!-- Allow serving .json, .env files needed by the app -->
    <staticContent>
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <!-- Security: block access to sensitive files -->
    <security>
      <requestFiltering>
        <hiddenSegments>
          <add segment=".env" />
          <add segment="data" />
          <add segment="prisma" />
          <add segment=".git" />
        </hiddenSegments>
      </requestFiltering>
    </security>

  </system.webServer>
</configuration>
