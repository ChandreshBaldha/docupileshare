# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/docupile_share?schema=public"

# ─────────────────────────────────────────────
# NEXT AUTH
# ─────────────────────────────────────────────
NEXTAUTH_SECRET="your-super-secret-key-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# ─────────────────────────────────────────────
# AWS S3 / MINIO
# ─────────────────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_S3_BUCKET="docupile-share"
# For MinIO (self-hosted), uncomment and set endpoint:
# AWS_S3_ENDPOINT="http://localhost:9000"
# AWS_S3_FORCE_PATH_STYLE="true"

# ─────────────────────────────────────────────
# EMAIL (choose one: RESEND or SMTP)
# ─────────────────────────────────────────────
EMAIL_PROVIDER="resend"   # "resend" | "smtp"

# Resend
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@yourdomain.com"
EMAIL_FROM_NAME="Docupile Share"

# SMTP (if EMAIL_PROVIDER=smtp)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"

# ─────────────────────────────────────────────
# TWILIO (SMS / OTP)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"
TWILIO_PHONE_NUMBER="+1234567890"

# ─────────────────────────────────────────────
# REDIS (for BullMQ job queue)
# ─────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Docupile Share"
OTP_EXPIRY_MINUTES="10"
MAX_FILE_SIZE_MB="50"
